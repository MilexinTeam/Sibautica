{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",

    "module": "commonjs",
    "target": "es2025",

    "types": ["node"],
    "lib": ["ESNext", "Decorators"],

    "strict": true,
    "skipLibCheck": true,

    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmitOnError": true
  }
}
